{
    "version": 4,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 2,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "common",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}"
        },

        {"name": "linux", "hidden": true },
        {"name": "windows", "hidden": true },


        {"name": "debug", "hidden": true, "cacheVariables": {"CMAKE_BUILD_TYPE": "Debug"}},
        {"name": "release", "hidden": true, "cacheVariables": {"CMAKE_BUILD_TYPE": "Release"}},

        {"name": "gcc", "hidden": true, "cacheVariables": {"CMAKE_C_COMPILER": "gcc", "CMAKE_CXX_COMPILER": "g++"}},

        {"name": "c_abi", "hidden": true, "cacheVariables": {"EXPORT_C_ABI": {"type": "BOOL", "value": true}}}, 
        {"name": "noabi", "hidden": true, "cacheVariables": {"EXPORT_C_ABI": {"type": "BOOL", "value": false}}}, 

        {
            "name": "linux-x86_64-gcc-debug",
            "inherits": ["common", "linux", "debug", "gcc", "c_abi"],
            "cacheVariables": {
                "BIN_FOLDER": "linux-x86_64-gcc"
            }
        },
        {
            "name": "linux-x86_64-gcc-noabi-debug",
            "inherits": ["common", "linux", "debug", "gcc", "noabi"],
            "cacheVariables": {
                "BIN_FOLDER": "linux-x86_64-gcc-noabi"
            }
        },
        {
            "name": "windows-x86_64-mingw64-debug",
            "inherits": ["common", "windows", "debug", "c_abi"],
            "cacheVariables": {
                "BIN_FOLDER": "windows-x86_64-gcc"
            }
        },
        {
            "name": "windows-x86_64-mingw64-noabi-debug",
            "inherits": ["common", "windows", "debug", "noabi"],
            "cacheVariables": {
                "BIN_FOLDER": "windows-x86_64-gcc-noabi"
            }
        }
    ]
}